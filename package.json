{
  "name": "open-canvas",
  "productName": "Open Canvas",
  "version": "0.1.0",
  "description": "Spatial whiteboard workspace for Open Canvas development",
  "main": "./out/main/index.cjs",
  "bin": {
    "open-canvas-cli": "./scripts/open-canvas-cli.mjs"
  },
  "type": "module",
  "scripts": {
    "cli": "node scripts/open-canvas-cli.mjs",
    "control:server": "node scripts/open-canvas-control-server.mjs",
    "dev": "node scripts/prepare-dev-electron.mjs && env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "install:mac-app": "bash ./install.sh",
    "check:diagram-fixtures": "node scripts/check-diagram-fixtures.mjs",
    "dist:mac": "node scripts/build-mac-icon.mjs && npm run build && electron-builder --mac dmg",
    "office:up": "docker compose -f docker-compose.onlyoffice.yml up -d",
    "office:down": "docker compose -f docker-compose.onlyoffice.yml down",
    "office:logs": "docker compose -f docker-compose.onlyoffice.yml logs --tail 150 -f onlyoffice",
    "preview": "node scripts/prepare-dev-electron.mjs && env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "^3.20.2",
    "@tiptap/markdown": "^3.20.2",
    "@tiptap/pm": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tldraw": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  },
  "build": {
    "appId": "com.saminyasar.opencanvas",
    "artifactName": "Open-Canvas-${version}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      "install.sh",
      "resources/**",
      ".codex/skills/open-canvas-diagrams/**",
      ".codex/skills/open-canvas-workspace/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/mac/icon.icns",
      "target": [
        "dmg"
      ]
    }
  }
}
